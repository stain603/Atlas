# enviroment configuration
# Copy this file to .env.local and adjust the values

# API Backend URL
VITE_API_BASE_URL=http://localhost:3001/api

# Informações da Aplicação
VITE_APP_TITLE="Cabedelo Fácil - Gestão Pública"
VITE_APP_VERSION="1.0.0"

# Analytics e Monitoramento
VITE_ENABLE_ANALYTICS=false
VITE_SENTRY_DSN=

# Configurações de Desenvolvimento
VITE_DEBUG_MODE=true
VITE_MOCK_API=false

# Limites e Configurações
VITE_MAX_FILE_SIZE=10485760
VITE_MAX_UPLOAD_FILES=5
VITE_REQUEST_TIMEOUT=30000

# Recursos Habilitados
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_NOTIFICATIONS=true

# Segurança
VITE_ENABLE_CORS=true
VITE_RATE_LIMIT_ENABLED=true
VITE_SESSION_TIMEOUT=1800

# Integrações Externas
VITE_GOOGLE_ANALYTICS_ID=
VITE_FACEBOOK_PIXEL_ID=
VITE_HOTJAR_ID=

# Mapas e Geolocalização
VITE_MAPS_API_KEY=
VITE_DEFAULT_LAT=-6.8915
VITE_DEFAULT_LNG=-35.2609

# Email e Notificações
VITE_EMAIL_SERVICE_ENABLED=true
VITE_SMS_SERVICE_ENABLED=false
VITE_WHATSAPP_ENABLED=false

# Backup e Sincronização
VITE_AUTO_SYNC_ENABLED=true
VITE_SYNC_INTERVAL=300000
VITE_BACKUP_ENABLED=true
